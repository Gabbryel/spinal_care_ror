<section class="promo-packages-home-section relative w-full px-0 max-sm:mt-[8rem] mt-[12rem] max-sm:mb-[6rem] row-span-1 col-span-full col-start-1">
  <div class="<%= div_widths %> my-0 mx-auto max-sm:px-4 px-3">
    <h2 class="text-center text-4xl word-wrap font-bold px-2 py-2 font-poppins">Pachete promoționale</h2>
    <p class="promo-section-lead">Oferte cu durată limitată, pregătite de echipa Spinal Care.</p>
  </div>

  <div class="relative <%= "#{div_widths} #{gaps_for_indexes}" %> mt-10 mb-0 mx-auto grid grid-cols-[repeat(auto-fit,minmax(260px,1fr))] justify-center max-sm:px-4 px-3 max-sm:gap-8 gap-6">
    <% @promo_packages.each_with_index do |promo_package, index| %>
      <div class="promo-home-card" style="animation-delay: <%= index * 0.12 %>s;" data-bs-toggle="modal" data-bs-target="#promoPhotoModal<%= promo_package.id %>">
        <% discount_percent =
             if promo_package.initial_price.to_f > 0 && promo_package.discounted_price.to_f > 0 &&
                promo_package.discounted_price < promo_package.initial_price
               (100 - (promo_package.discounted_price * 100.0 / promo_package.initial_price)).round
             end %>

        <% if promo_package.photo.attached? %>
          <div class="promo-home-photo">
            <%= cl_image_tag(promo_package.photo.key, quality: 85, width: 600, crop: "fill", gravity: "auto") %>
            <% if discount_percent %>
              <span class="promo-discount-ribbon">-<%= discount_percent %>%</span>
            <% end %>
            <div class="promo-overlay">
              <% if promo_package.active? %>
                <span class="promo-badge active">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M6 3.75A2.75 2.75 0 018.75 1h2.5A2.75 2.75 0 0114 3.75v.443c.572.055 1.14.122 1.706.2C17.053 4.582 18 5.75 18 7.07V19a2 2 0 01-2 2H4a2 2 0 01-2-2V7.07c0-1.32.947-2.488 2.294-2.676A41.047 41.047 0 016 4.193V3.75zm6.5 0v.325a41.622 41.622 0 00-5 0V3.75c0-.69.56-1.25 1.25-1.25h2.5c.69 0 1.25.56 1.25 1.25zM10 10a1 1 0 00-1 1v.01a1 1 0 001 1h.01a1 1 0 001-1V11a1 1 0 00-1-1H10z" clip-rule="evenodd" />
                  </svg>
                  Activ
                </span>
              <% else %>
                <span class="promo-badge expired">Expirat</span>
              <% end %>
            </div>
          </div>
        <% else %>
          <div class="promo-home-icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
              <path fill-rule="evenodd" d="M5.166 2.621v.858c-1.035.148-2.059.33-3.071.543a.75.75 0 00-.584.859 6.753 6.753 0 006.138 5.6 6.73 6.73 0 002.743 1.346A6.707 6.707 0 019.279 15H8.54c-1.036 0-1.875.84-1.875 1.875V19.5h-.75a2.25 2.25 0 00-2.25 2.25c0 .414.336.75.75.75h15a.75.75 0 00.75-.75 2.25 2.25 0 00-2.25-2.25h-.75v-2.625c0-1.036-.84-1.875-1.875-1.875h-.739a6.706 6.706 0 01-1.112-3.173 6.73 6.73 0 002.743-1.347 6.753 6.753 0 006.139-5.6.75.75 0 00-.585-.858 47.077 47.077 0 00-3.07-.543V2.62a.75.75 0 00-.658-.744 49.22 49.22 0 00-6.093-.377c-2.063 0-4.096.128-6.093.377a.75.75 0 00-.657.744zm0 2.629c0 1.196.312 2.32.857 3.294A5.266 5.266 0 013.16 5.337a45.6 45.6 0 012.006-.343v.256zm13.5 0v-.256c.674.1 1.343.214 2.006.343a5.265 5.265 0 01-2.863 3.207 6.72 6.72 0 00.857-3.294z" clip-rule="evenodd" />
            </svg>
            <% if discount_percent %>
              <span class="promo-discount-ribbon">-<%= discount_percent %>%</span>
            <% end %>
          </div>
        <% end %>
        
        <div class="promo-home-content">
          <h3 class="promo-home-title"><%= promo_package.name %></h3>
          <% if promo_package.sub_name.present? %>
            <p class="promo-home-subtitle"><%= promo_package.sub_name %></p>
          <% end %>
          
          <% if promo_package.initial_price.present? || promo_package.discounted_price.present? %>
            <div class="promo-home-pricing">
              <% if promo_package.initial_price.present? && promo_package.discounted_price.present? %>
                <span class="home-price-original"><%= number_to_currency(promo_package.initial_price, unit: 'RON', separator: ',', delimiter: '.', format: '%n %u') %></span>
                <span class="home-price-discounted"><%= number_to_currency(promo_package.discounted_price, unit: 'RON', separator: ',', delimiter: '.', format: '%n %u') %></span>
              <% elsif promo_package.discounted_price.present? %>
                <span class="home-price-discounted"><%= number_to_currency(promo_package.discounted_price, unit: 'RON', separator: ',', delimiter: '.', format: '%n %u') %></span>
              <% elsif promo_package.initial_price.present? %>
                <span class="home-price-discounted"><%= number_to_currency(promo_package.initial_price, unit: 'RON', separator: ',', delimiter: '.', format: '%n %u') %></span>
              <% end %>
            </div>
          <% end %>

          <% if promo_package.benefits.present? %>
            <div class="promo-home-benefits">
              <%= promo_package.benefits %>
            </div>
          <% end %>

          <div class="promo-home-footer">
            <div class="promo-home-date">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M5.75 2a.75.75 0 01.75.75V4h7V2.75a.75.75 0 011.5 0V4h.25A2.75 2.75 0 0118 6.75v8.5A2.75 2.75 0 0115.25 18H4.75A2.75 2.75 0 012 15.25v-8.5A2.75 2.75 0 014.75 4H5V2.75A.75.75 0 015.75 2zm-1 5.5c-.69 0-1.25.56-1.25 1.25v6.5c0 .69.56 1.25 1.25 1.25h10.5c.69 0 1.25-.56 1.25-1.25v-6.5c0-.69-.56-1.25-1.25-1.25H4.75z" clip-rule="evenodd" />
              </svg>
              <span>Până la <%= promo_package.valid_until.strftime('%d.%m.%Y') %></span>
            </div>
            <% if promo_package.photo.attached? %>
              <span class="promo-home-cta">Detalii →</span>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
  
  <div class="text-center mt-12">
    <%= link_to promotii_path, class: 'inline-block text-xl font-semibold text-gray-700 hover:text-orange-600 transition-colors font-poppins' do %>
      Vezi toate pachete →
    <% end %>
  </div>
</section>

<!-- Promo Photo Modals -->
<% @promo_packages.each do |promo_package| %>
  <% if promo_package.photo.attached? %>
    <div class="modal fade" id="promoPhotoModal<%= promo_package.id %>" tabindex="-1" aria-labelledby="promoPhotoModalLabel<%= promo_package.id %>" aria-hidden="true">
      <div class="modal-dialog modal-dialog-centered modal-lg" style="max-height: 80vh;">
        <div class="modal-content" style="background: transparent; border: none; height: 80vh;">
          <div class="modal-body promo-modal-body">
            <div class="promo-modal-figure">
              <%= cl_image_tag(promo_package.photo.key, quality: 95, width: 1200, crop: "limit", class: "rounded-3 promo-modal-image") %>
              <button type="button" class="promo-modal-close" data-bs-dismiss="modal" aria-label="Închide">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" aria-hidden="true">
                  <path d="M6 6l12 12M18 6L6 18" />
                </svg>
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>
  <% end %>
<% end %>

<style>
  /* Close control for the promo photo modal: opaque so it stays legible
     against both the dark backdrop and any light area of the poster. */
  .promo-modal-body {
    padding: 0;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Shrink-wraps the poster so the close control can sit on the image's
     own corner rather than the much wider modal-lg box. */
  .promo-modal-figure {
    position: relative;
    display: inline-flex;
    max-width: 100%;
    max-height: 100%;
  }

  .promo-modal-image {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    display: block;
  }

  .promo-modal-close {
    position: absolute;
    top: -0.75rem;
    right: -0.75rem;
    z-index: 1051;
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    border: 2px solid rgba(255, 255, 255, 0.9);
    border-radius: 50%;
    background: #1f2937;
    color: #fff;
    cursor: pointer;
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.45);
    transition: background 0.2s ease, transform 0.2s ease;
  }

  .promo-modal-close svg {
    width: 20px;
    height: 20px;
  }

  .promo-modal-close:hover {
    background: #ea580c;
    transform: scale(1.06);
  }

  .promo-modal-close:focus-visible {
    outline: 3px solid #f97316;
    outline-offset: 2px;
  }

  @media (max-width: 575.98px) {
    .promo-modal-close {
      top: -0.25rem;
      right: -0.25rem;
      width: 40px;
      height: 40px;
    }
  }

  .promo-section-lead {
    margin: 0.35rem auto 0;
    max-width: 34rem;
    text-align: center;
    font-size: 1rem;
    line-height: 1.6;
    color: #6b7280;
  }

  /* Every dimension below is expressed against --promo-scale, so the whole
     card shrinks or grows uniformly from this one value. */
  .promo-home-card {
    --promo-scale: 0.9;

    position: relative;
    background: #fff;
    border: 1px solid #eceff3;
    border-radius: calc(18px * var(--promo-scale));
    overflow: hidden;
    box-shadow: 0 1px 2px rgba(16, 24, 40, 0.04), 0 8px 24px -12px rgba(16, 24, 40, 0.12);
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1),
                box-shadow 0.35s cubic-bezier(0.4, 0, 0.2, 1),
                border-color 0.35s ease;
    cursor: pointer;
    width: 100%;
    min-width: 0;
    max-width: calc(340px * var(--promo-scale));
    justify-self: center;
    display: flex;
    flex-direction: column;
    animation: promoCardIn 0.6s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  @keyframes promoCardIn {
    from { opacity: 0; transform: translateY(18px); }
    to   { opacity: 1; transform: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    .promo-home-card { animation: none; }
    .promo-home-card,
    .promo-home-photo img,
    .promo-home-cta { transition: none; }
  }

  .promo-home-card:hover {
    transform: translateY(-6px);
    border-color: #fed7aa;
    box-shadow: 0 2px 4px rgba(16, 24, 40, 0.04), 0 24px 40px -20px rgba(234, 88, 12, 0.45);
  }

  .promo-home-card:focus-visible {
    outline: 2px solid #f97316;
    outline-offset: 3px;
  }

  /* ---- media ---- */

  /* Posters are portrait, so a taller window shows far more of the
     artwork before `cover` crops it. */
  .promo-home-photo {
    position: relative;
    width: 100%;
    aspect-ratio: 3 / 4;
    overflow: hidden;
    background: #f3f4f6;
  }

  .promo-home-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .promo-home-card:hover .promo-home-photo img {
    transform: scale(1.06);
  }

  .promo-home-icon {
    position: relative;
    width: 100%;
    aspect-ratio: 3 / 4;
    background: linear-gradient(135deg, #fb923c 0%, #ea580c 100%);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .promo-home-icon svg {
    width: calc(84px * var(--promo-scale));
    height: calc(84px * var(--promo-scale));
    color: #fff;
    opacity: 0.92;
    filter: drop-shadow(0 4px 8px rgba(0, 0, 0, 0.18));
  }

  /* ---- badges ---- */

  .promo-discount-ribbon {
    position: absolute;
    top: calc(0.875rem * var(--promo-scale));
    left: calc(0.875rem * var(--promo-scale));
    z-index: 2;
    display: inline-flex;
    align-items: center;
    padding: calc(0.4rem * var(--promo-scale)) calc(0.7rem * var(--promo-scale));
    border-radius: calc(10px * var(--promo-scale));
    background: linear-gradient(135deg, #f97316 0%, #ea580c 100%);
    color: #fff;
    font-size: calc(0.875rem * var(--promo-scale));
    font-weight: 800;
    letter-spacing: 0.02em;
    line-height: 1;
    box-shadow: 0 6px 14px -4px rgba(234, 88, 12, 0.65);
  }

  .promo-overlay {
    position: absolute;
    top: calc(0.875rem * var(--promo-scale));
    right: calc(0.875rem * var(--promo-scale));
    z-index: 2;
  }

  .promo-badge {
    display: inline-flex;
    align-items: center;
    gap: calc(0.35rem * var(--promo-scale));
    padding: calc(0.4rem * var(--promo-scale)) calc(0.7rem * var(--promo-scale));
    border-radius: 9999px;
    font-size: calc(0.7rem * var(--promo-scale));
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    line-height: 1;
    backdrop-filter: blur(10px);
  }

  .promo-badge svg {
    width: calc(13px * var(--promo-scale));
    height: calc(13px * var(--promo-scale));
  }

  .promo-badge.active {
    background: rgba(255, 255, 255, 0.94);
    color: #15803d;
    box-shadow: 0 2px 8px rgba(16, 24, 40, 0.16);
  }

  .promo-badge.expired {
    background: rgba(255, 255, 255, 0.94);
    color: #b91c1c;
    box-shadow: 0 2px 8px rgba(16, 24, 40, 0.16);
  }

  /* ---- content ---- */

  .promo-home-content {
    padding: calc(1.15rem * var(--promo-scale)) calc(1.15rem * var(--promo-scale)) calc(0.9rem * var(--promo-scale));
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .promo-home-title {
    font-size: calc(1.15rem * var(--promo-scale));
    font-weight: 700;
    color: #111827;
    margin: 0;
    line-height: 1.3;
    letter-spacing: -0.01em;
  }

  .promo-home-subtitle {
    font-size: calc(0.875rem * var(--promo-scale));
    color: #6b7280;
    margin: calc(0.3rem * var(--promo-scale)) 0 0;
    line-height: 1.45;
  }

  .promo-home-pricing {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: calc(0.55rem * var(--promo-scale));
    margin: calc(0.85rem * var(--promo-scale)) 0 0;
  }

  .home-price-discounted {
    font-size: calc(1.6rem * var(--promo-scale));
    font-weight: 800;
    color: #ea580c;
    line-height: 1.1;
    letter-spacing: -0.02em;
  }

  .home-price-original {
    font-size: calc(0.9rem * var(--promo-scale));
    color: #9ca3af;
    text-decoration: line-through;
    line-height: 1.3;
    order: 2;
  }

  .promo-home-benefits {
    margin: calc(0.9rem * var(--promo-scale)) 0 0;
    padding: calc(0.8rem * var(--promo-scale)) calc(0.9rem * var(--promo-scale));
    background: #fafafa;
    border: 1px solid #f1f2f4;
    border-radius: calc(12px * var(--promo-scale));
    font-size: calc(0.85rem * var(--promo-scale));
    color: #4b5563;
    line-height: 1.55;
  }

  .promo-home-benefits p { margin: 0; }

  .promo-home-benefits ul {
    margin: 0;
    padding-left: calc(1.1rem * var(--promo-scale));
    list-style: none;
  }

  .promo-home-benefits li {
    position: relative;
    margin-bottom: calc(0.3rem * var(--promo-scale));
    padding-left: 0.1rem;
  }

  .promo-home-benefits li::before {
    content: "";
    position: absolute;
    left: calc(-0.85rem * var(--promo-scale));
    top: 0.55em;
    width: calc(5px * var(--promo-scale));
    height: calc(5px * var(--promo-scale));
    border-radius: 50%;
    background: #f97316;
  }

  .promo-home-benefits li:last-child { margin-bottom: 0; }

  /* ---- footer ---- */

  .promo-home-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: calc(0.75rem * var(--promo-scale));
    margin-top: auto;
    padding-top: calc(0.9rem * var(--promo-scale));
    border-top: 1px solid #f1f2f4;
  }

  .promo-home-date {
    display: flex;
    align-items: center;
    gap: calc(0.4rem * var(--promo-scale));
    font-size: calc(0.82rem * var(--promo-scale));
    color: #6b7280;
    line-height: 1.3;
  }

  .promo-home-date svg {
    width: calc(16px * var(--promo-scale));
    height: calc(16px * var(--promo-scale));
    color: #f97316;
    flex-shrink: 0;
  }

  .promo-home-cta {
    font-size: calc(0.82rem * var(--promo-scale));
    font-weight: 700;
    color: #ea580c;
    white-space: nowrap;
    opacity: 0.75;
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .promo-home-card:hover .promo-home-cta {
    opacity: 1;
    transform: translateX(2px);
  }

  @media (max-width: 768px) {
    .promo-packages-home-section {
      padding: 2rem 0;
    }

    .promo-section-lead {
      font-size: 0.95rem;
    }

    .promo-home-card {
      max-width: 100%;
    }
  }
</style>
